<Window x:Class="GuessOfWord.AnagramWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Головоломки — Анаграмма"
        Height="970"
        Width="720"
        WindowStyle="None"
        ResizeMode="NoResize"
        Loaded="Window_Loaded"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Width" Value="170"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#5C718F"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <Border Height="34"
            VerticalAlignment="Top"
            Background="Transparent"
            Panel.ZIndex="10"
            MouseLeftButtonDown="Window_MouseLeftButtonDown">
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32">
                <Border Padding="20"
                        CornerRadius="24"
                        Background="#AA0F172A">
                    <StackPanel>
                        <DockPanel LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="Анаграмма"
                                           Foreground="White"
                                           FontSize="34"
                                           FontWeight="Bold"/>

                                <TextBlock Text="Составьте несколько слов из букв большого слова."
                                           Foreground="#DDEBFF"
                                           FontSize="15"/>
                            </StackPanel>

                            <Button DockPanel.Dock="Right"
                                    Content="В меню"
                                    Style="{StaticResource MenuButton}"
                                    Background="#32568A"
                                    Click="Main_Click"/>
                        </DockPanel>

                        <Border Background="#1E293B"
                                CornerRadius="18"
                                Padding="18"
                                Margin="0,24,0,18">
                            <StackPanel>
                                <TextBlock Text="Главное слово:"
                                           Foreground="#DDEBFF"
                                           FontSize="15"
                                           TextAlignment="Center"/>

                                <TextBlock x:Name="BaseWordText"
                                           Text="- - - - -"
                                           Foreground="White"
                                           FontSize="42"
                                           FontWeight="Bold"
                                           TextAlignment="Center"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <TextBlock x:Name="TaskText"
                                   Text="Нужно найти несколько слов."
                                   Foreground="#DDEBFF"
                                   FontSize="16"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Margin="0,0,0,14"/>

                        <TextBox x:Name="AnswerBox"
                                 Height="48"
                                 FontSize="24"
                                 MaxLength="10"
                                 CharacterCasing="Upper"
                                 TextAlignment="Center"
                                 Margin="0,0,0,12"
                                 KeyDown="AnswerBox_KeyDown"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="Проверить"
                                    Click="Check_Click"
                                    Style="{StaticResource MenuButton}"
                                    Background="#2563EB"/>

                            <Button Content="Подсказка"
                                    Click="Hint_Click"
                                    Style="{StaticResource MenuButton}"/>

                            <Button Content="Следующее"
                                    Click="Next_Click"
                                    Style="{StaticResource MenuButton}"/>
                        </StackPanel>

                        <TextBlock x:Name="StatusText"
                                   Text="Загрузка..."
                                   Foreground="White"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,18,0,10"/>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="1.2*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="#661E293B"
                                    CornerRadius="16"
                                    Padding="14">
                                <StackPanel>
                                    <TextBlock Text="Кроссворд ответов:"
                                               Foreground="White"
                                               FontSize="17"
                                               FontWeight="Bold"
                                               Margin="0,0,0,10"/>

                                    <StackPanel x:Name="CrosswordPanel"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Background="#661E293B"
                                    CornerRadius="16"
                                    Padding="14">
                                <StackPanel>
                                    <TextBlock Text="Другие подходящие слова:"
                                               Foreground="White"
                                               FontSize="17"
                                               FontWeight="Bold"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,10"/>

                                    <TextBlock Text="Если слово можно составить из букв, но оно не было загадано, оно попадет сюда."
                                               Foreground="#DDEBFF"
                                               TextWrapping="Wrap"
                                               FontSize="13"
                                               Margin="0,0,0,10"/>

                                    <ListBox x:Name="ExtraWordsList"
                                             Height="270"
                                             FontSize="16"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>