<Window x:Class="GuessOfWord.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки"
        Height="460"
        Width="500"
        ResizeMode="NoResize"
        Loaded="Window_Loaded">
    <Window.Resources>
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Width" Value="190"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#5C718F"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <Border Width="380"
                Padding="28"
                CornerRadius="28"
                Background="#AA0F172A"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Настройки"
                           Foreground="White"
                           FontSize="34"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           Margin="0,0,0,10"/>

                <TextBlock Text="Выберите фон. Он будет применяться ко всем окнам игры."
                           Foreground="#DDEBFF"
                           FontSize="15"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,24"/>

                <TextBlock Text="Фон:"
                           Foreground="White"
                           FontSize="17"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>

                <ComboBox x:Name="ThemeComboBox"
                          Height="40"
                          FontSize="16"
                          Margin="0,0,0,24"
                          SelectionChanged="ThemeComboBox_SelectionChanged">
                    <ComboBoxItem Content="Темный" Tag="Dark"/>
                    <ComboBoxItem Content="Океан" Tag="Ocean"/>
                    <ComboBoxItem Content="Фиолетовый" Tag="Violet"/>
                    <ComboBoxItem Content="Светлый" Tag="Light"/>
                </ComboBox>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="Сохранить"
                            Style="{StaticResource MenuButton}"
                            Background="#2563EB"
                            Click="Save_Click" Width="126"/>

                    <Button Content="В меню"
                            Style="{StaticResource MenuButton}"
                            Background="#32568A"
                            Click="Main_Click" Width="120"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>