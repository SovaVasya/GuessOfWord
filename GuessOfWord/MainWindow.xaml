<Window x:Class="GuessOfWord.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Головоломки — Угадай слово"
        Height="970"
        Width="660"
        WindowStyle="None"
        ResizeMode="NoResize"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="14,4"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#5C718F"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="KeyboardButton" TargetType="Button" BasedOn="{StaticResource MenuButton}">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <Border Height="34"
            VerticalAlignment="Top"
            Background="Transparent"
            Panel.ZIndex="10"
            MouseLeftButtonDown="Window_MouseLeftButtonDown">
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32">
                <Border Padding="18"
                        CornerRadius="22"
                        Background="#AA0F172A">
                    <StackPanel>
                        <DockPanel LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="Угадай слово"
                                           Foreground="White"
                                           FontSize="34"
                                           FontWeight="Bold"/>

                                <TextBlock Text="Введите простое слово из 5 букв. Есть 6 попыток."
                                           Foreground="#DDEBFF"
                                           FontSize="15"/>
                            </StackPanel>

                            <StackPanel DockPanel.Dock="Right"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Button Content="Новая игра"
                                        Style="{StaticResource MenuButton}"
                                        Background="#16A34A"
                                        Click="NewGame_Click"/>

                                <Button Content="В меню"
                                        Style="{StaticResource MenuButton}"
                                        Background="#32568A"
                                        Click="MainMenu_Click"/>
                            </StackPanel>
                        </DockPanel>

                        <Expander Header="Правила игры"
                                  IsExpanded="True"
                                  Foreground="White"
                                  FontSize="15"
                                  FontWeight="SemiBold"
                                  Margin="0,16,0,0">
                            <Border Margin="0,8,0,0"
                                    Padding="14"
                                    CornerRadius="14"
                                    Background="#661E293B">
                                <StackPanel>
                                    <TextBlock Text="• Нужно угадать слово из 5 букв."
                                               Foreground="#DDEBFF"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="• Зеленая клетка — буква стоит на правильном месте."
                                               Foreground="#DDEBFF"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0"/>
                                    <TextBlock Text="• Синяя клетка — буква есть в слове, но стоит не там."
                                               Foreground="#DDEBFF"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0"/>
                                    <TextBlock Text="• Темная клетка — такой буквы в слове нет."
                                               Foreground="#DDEBFF"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Expander>
                    </StackPanel>
                </Border>

                <UniformGrid x:Name="BoardGrid"
                             Rows="6"
                             Columns="5"
                             Width="350"
                             Height="420"
                             HorizontalAlignment="Center"
                             Margin="0,24,0,0"/>

                <TextBlock x:Name="StatusText"
                           Text="Загрузка словаря..."
                           Foreground="White"
                           FontSize="16"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,18,0,0"/>

                <Border Margin="0,22,0,0"
                        Padding="16"
                        CornerRadius="22"
                        Background="#AA0F172A">
                    <StackPanel>
                        <StackPanel x:Name="KeyboardPanel"
                                    HorizontalAlignment="Center"/>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,12,0,0">
                            <Button Content="⌫"
                                    Width="90"
                                    Style="{StaticResource MenuButton}"
                                    Click="BackspaceButton_Click"/>

                            <Button Content="Проверить слово"
                                    Width="230"
                                    Background="#2563EB"
                                    Style="{StaticResource MenuButton}"
                                    Click="EnterButton_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>