<Window x:Class="GuessOfWord.MemoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Головоломки — Память"
        Height="840"
        Width="680"
        ResizeMode="NoResize"
        Loaded="Window_Loaded">
    <Window.Resources>
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Width" Value="180"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#5C718F"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MemoryButton" TargetType="Button">
            <Setter Property="Width" Value="86"/>
            <Setter Property="Height" Value="86"/>
            <Setter Property="Margin" Value="7"/>
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#334155"/>
            <Setter Property="BorderBrush" Value="#64748B"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32">
                <Border Padding="20"
                        CornerRadius="24"
                        Background="#AA0F172A">
                    <StackPanel>
                        <DockPanel LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="Память"
                                           Foreground="White"
                                           FontSize="34"
                                           FontWeight="Bold"/>

                                <TextBlock Text="Запомните последовательность и повторите её."
                                           Foreground="#DDEBFF"
                                           FontSize="15"/>
                            </StackPanel>

                            <Button DockPanel.Dock="Right"
                                    Content="В меню"
                                    Style="{StaticResource MenuButton}"
                                    Background="#32568A"
                                    Click="Main_Click"/>
                        </DockPanel>

                        <Grid Margin="0,18,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="LevelText"
                                       Grid.Column="0"
                                       Text="Уровень: 1"
                                       Foreground="White"
                                       FontSize="17"
                                       FontWeight="Bold"
                                       TextAlignment="Center"/>

                            <TextBlock x:Name="SymbolsText"
                                       Grid.Column="1"
                                       Text="Символов: 9"
                                       Foreground="White"
                                       FontSize="17"
                                       FontWeight="Bold"
                                       TextAlignment="Center"/>

                            <TextBlock x:Name="RecordText"
                                       Grid.Column="2"
                                       Text="Рекорд: 0"
                                       Foreground="#FACC15"
                                       FontSize="17"
                                       FontWeight="Bold"
                                       TextAlignment="Center"/>
                        </Grid>

                        <TextBlock x:Name="StatusText"
                                   Text="Нажмите «Начать»."
                                   Foreground="White"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,14,0,10"/>

                        <UniformGrid x:Name="SymbolsGrid"
                                     Rows="4"
                                     Columns="4"
                                     Width="420"
                                     Height="420"
                                     HorizontalAlignment="Center"
                                     Margin="0,10,0,10"/>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,14,0,0">
                            <Button x:Name="StartButton"
                                    Content="Начать"
                                    Style="{StaticResource MenuButton}"
                                    Background="#2563EB"
                                    Click="Start_Click"/>

                            <Button Content="Сначала"
                                    Style="{StaticResource MenuButton}"
                                    Click="Restart_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>