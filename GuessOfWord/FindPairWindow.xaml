<Window x:Class="GuessOfWord.FindPairWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Головоломки — Найди пару"
        Height="890"
        Width="680"
        ResizeMode="NoResize"
        Loaded="Window_Loaded">
    <Window.Resources>
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Width" Value="170"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#5C718F"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardButton" TargetType="Button">
            <Setter Property="Width" Value="105"/>
            <Setter Property="Height" Value="105"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="FontSize" Value="34"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="BorderBrush" Value="#64748B"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32">
                <Border Padding="20"
                        CornerRadius="24"
                        Background="#AA0F172A">
                    <StackPanel>
                        <DockPanel LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="Найди пару"
                                           Foreground="White"
                                           FontSize="34"
                                           FontWeight="Bold"/>

                                <TextBlock Text="Открывайте карточки и ищите одинаковые символы."
                                           Foreground="#DDEBFF"
                                           FontSize="15"/>
                            </StackPanel>

                            <Button DockPanel.Dock="Right"
                                    Content="В меню"
                                    Style="{StaticResource MenuButton}"
                                    Background="#32568A"
                                    Click="Main_Click"/>
                        </DockPanel>

                        <Grid Margin="0,18,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="MovesText"
                                       Grid.Column="0"
                                       Text="Ходы: 0"
                                       Foreground="White"
                                       FontSize="17"
                                       FontWeight="Bold"
                                       TextAlignment="Center"/>

                            <TextBlock x:Name="PairsText"
                                       Grid.Column="1"
                                       Text="Пары: 0/8"
                                       Foreground="White"
                                       FontSize="17"
                                       FontWeight="Bold"
                                       TextAlignment="Center"/>

                            <TextBlock x:Name="RecordText"
                                       Grid.Column="2"
                                       Text="Рекорд: -"
                                       Foreground="#FACC15"
                                       FontSize="17"
                                       FontWeight="Bold"
                                       TextAlignment="Center"/>
                        </Grid>

                        <TextBlock x:Name="StatusText"
                                   Text="Откройте две карточки."
                                   Foreground="#DDEBFF"
                                   FontSize="16"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,10,0,14"/>

                        <Border HorizontalAlignment="Center"
                                Padding="12"
                                CornerRadius="24"
                                Background="#661E293B">
                            <UniformGrid x:Name="CardsGrid"
                                         Rows="4"
                                         Columns="4"
                                         Width="500"
                                         Height="500"/>
                        </Border>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,18,0,0">
                            <Button Content="Новая игра"
                                    Style="{StaticResource MenuButton}"
                                    Background="#2563EB"
                                    Click="NewGame_Click"/>

                            <Button Content="Правила"
                                    Style="{StaticResource MenuButton}"
                                    Click="Rules_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>