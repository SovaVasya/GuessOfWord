<Window x:Class="GuessOfWord.OpenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Головоломки"
        Height="760"
        Width="560"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Height" Value="50"/>
            <Setter Property="Width" Value="260"/>
            <Setter Property="Margin" Value="0,8"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#5C718F"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <Border Width="420"
                Padding="32"
                CornerRadius="30"
                Background="#AA0F172A"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="ГОЛОВОЛОМКИ"
                           Foreground="White"
                           FontSize="40"
                           FontWeight="Bold"
                           TextAlignment="Center"/>

                <TextBlock Text="Дипломный проект"
                           Foreground="#93C5FD"
                           FontSize="22"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           Margin="0,4,0,8"/>

                <TextBlock Text="Набор логических и словесных игр"
                           Foreground="#DDEBFF"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           FontSize="15"
                           Margin="0,0,0,24"/>

                <Button Content="Угадай слово"
                        Click="Game"
                        Style="{StaticResource MenuButton}"
                        Background="#16A34A"/>

                <Button Content="Анаграмма"
                        Click="Anagram"
                        Style="{StaticResource MenuButton}" 
                        Background="CadetBlue"/>


                <Button Content="Память"
                        Click="Memory"
                        Style="{StaticResource MenuButton}"
                        Background="DarkSeaGreen"/>


                <Button Content="Настройки"
                        Click="Settings"
                        Style="{StaticResource MenuButton}"/>

                <Button Content="Выйти"
                        Click="Exit"
                        Style="{StaticResource MenuButton}"
                        Background="#32568A"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>